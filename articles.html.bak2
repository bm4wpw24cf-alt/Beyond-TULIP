<script>
  const filterButtons = document.querySelectorAll('.filter-tag');
  const articleRows = document.querySelectorAll('.article-row');
  const emptyNote = document.getElementById('emptyNote');
  const defaultNote = document.getElementById('defaultNote');

  function applyFilter(category){
    let visibleCount = 0;

    articleRows.forEach(row => {
      const matches = category === 'all' || row.getAttribute('data-category') === category;
      row.style.display = matches ? '' : 'none';
      if(matches) visibleCount++;
    });

    // "All" always keeps the standing note about more articles coming;
    // any other category with zero matches shows the empty-category note instead.
    if(category === 'all'){
      emptyNote.hidden = true;
      defaultNote.hidden = false;
    } else if(visibleCount === 0){
      emptyNote.hidden = false;
      defaultNote.hidden = true;
    } else {
      emptyNote.hidden = true;
      defaultNote.hidden = true;
    }
  }

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      filterButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyFilter(btn.getAttribute('data-category'));
    });
  });
</script>

